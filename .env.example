# FraudCell — Root environment variable template
# Copy this file to .env and replace placeholder values with real secrets.
# NEVER commit .env to version control.

# ─── identity-service database ────────────────
IDENTITY_DB_NAME=identity_db
IDENTITY_DB_USER=identity_user
IDENTITY_DB_PASSWORD=changeme_identity

# ─── transaction-service database ─────────────
TRANSACTION_DB_NAME=transaction_db
TRANSACTION_DB_USER=transaction_user
TRANSACTION_DB_PASSWORD=changeme_transaction

# ─── ai-service database ──────────────────────
AI_DB_NAME=ai_db
AI_DB_USER=ai_user
AI_DB_PASSWORD=changeme_ai

# ─── gamification-service database ───────────
GAMIFICATION_DB_NAME=gamification_db
GAMIFICATION_DB_USER=gamification_user
GAMIFICATION_DB_PASSWORD=changeme_gamification

# ─── RabbitMQ ─────────────────────────────────
RABBITMQ_USER=rabbit
RABBITMQ_PASSWORD=changeme_rabbit
# URL used by backend services (auto-composed from above, override if needed)
RABBITMQ_URL=amqp://rabbit:changeme_rabbit@rabbitmq:5672/

# ─── Redis ────────────────────────────────────
REDIS_URL=redis://redis:6379/0
