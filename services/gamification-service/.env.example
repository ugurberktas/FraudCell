# Gamification Service environment variables
# Copy this file to .env and adjust values as needed.

SERVICE_NAME=gamification-service
VERSION=0.1.0
DEBUG=false
DATABASE_URL=postgresql+psycopg://gamification_user:change_me@localhost:5432/gamification_db
RABBITMQ_URL=amqp://rabbit:change_me@rabbitmq:5672/
EVENT_EXCHANGE=fraudcell.events
CASE_DECISION_QUEUE=gamification.case-decisions.v1
CONSUMER_PREFETCH=10
JWT_SECRET=replace_with_shared_identity_jwt_secret_at_least_32_characters
JWT_ALGORITHM=HS256
JWT_ISSUER=fraudcell-identity
JWT_AUDIENCE=fraudcell-platform
DEMO_CARD_ANALYST_ID=00000000-0000-0000-0000-000000000001
DEMO_ACCOUNT_ANALYST_ID=00000000-0000-0000-0000-000000000002
DEMO_AML_ANALYST_ID=00000000-0000-0000-0000-000000000003
