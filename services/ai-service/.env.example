# AI Service environment variables
# Copy this file to .env and adjust values as needed.

SERVICE_NAME=ai-service
VERSION=0.1.0
DEBUG=false
DATABASE_URL=postgresql+psycopg://ai_user:change_me@localhost:5432/ai_db
INTERNAL_SERVICE_KEY=replace_with_internal_service_key
MODEL_ARTIFACT_PATH=artifacts/fraud_model.joblib
MODEL_METADATA_PATH=artifacts/model_metadata.json

# Demo analyst Identity UUIDs (replace with real ANALYST user IDs)
DEMO_CARD_ANALYST_ID=00000000-0000-0000-0000-000000000001
DEMO_ACCOUNT_ANALYST_ID=00000000-0000-0000-0000-000000000002
DEMO_LAUNDERING_ANALYST_ID=00000000-0000-0000-0000-000000000003
DEMO_AML_ANALYST_ID=00000000-0000-0000-0000-000000000003
