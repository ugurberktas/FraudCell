# Transaction Service environment variables
# Copy this file to .env and adjust values as needed.

SERVICE_NAME=transaction-service
VERSION=0.1.0
DEBUG=false
DATABASE_URL=postgresql+psycopg://transaction_user:change_me@localhost:5432/transaction_db
JWT_SECRET=replace_with_shared_identity_jwt_secret_at_least_32_characters
JWT_ALGORITHM=HS256
JWT_ISSUER=fraudcell-identity
JWT_AUDIENCE=fraudcell-platform
AI_SERVICE_URL=http://ai-service:8000
INTERNAL_SERVICE_KEY=replace_with_internal_service_key
AI_TIMEOUT_SECONDS=3
