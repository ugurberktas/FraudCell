# Identity Service environment variables
# Copy this file to .env and adjust values as needed.

SERVICE_NAME=identity-service
VERSION=0.1.0
DEBUG=false
DEMO_OTP_CODE=1234

# Admin bootstrap (replace every placeholder before running the CLI)
BOOTSTRAP_ADMIN_FIRST_NAME=CHANGE_ME
BOOTSTRAP_ADMIN_LAST_NAME=CHANGE_ME
BOOTSTRAP_ADMIN_EMAIL=change-me@example.invalid
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
