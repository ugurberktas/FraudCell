# Identity Service environment variables
# Copy this file to .env and adjust values as needed.

SERVICE_NAME=identity-service
VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development
DEMO_OTP_CODE=1234
DEMO_CUSTOMER_GSM=05550000001
DEMO_ADMIN_PASSWORD=CHANGE_ME_STRONG_DEMO_ADMIN_PASSWORD
DEMO_SUPERVISOR_PASSWORD=CHANGE_ME_STRONG_DEMO_SUPERVISOR_PASSWORD
DEMO_ANALYST_PASSWORD=CHANGE_ME_STRONG_DEMO_ANALYST_PASSWORD

# Admin bootstrap (replace every placeholder before running the CLI)
BOOTSTRAP_ADMIN_FIRST_NAME=CHANGE_ME
BOOTSTRAP_ADMIN_LAST_NAME=CHANGE_ME
BOOTSTRAP_ADMIN_EMAIL=change-me@example.invalid
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Authentication (replace JWT_SECRET with at least 32 random characters)
JWT_SECRET=CHANGE_ME_WITH_A_RANDOM_32_PLUS_CHARACTER_SECRET
JWT_ALGORITHM=HS256
JWT_ISSUER=fraudcell-identity
JWT_AUDIENCE=fraudcell-platform
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
